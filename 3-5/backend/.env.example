# SQLite database (Prisma)
DATABASE_URL="file:./dev.db"

# Server
PORT=3001
NODE_ENV=development

# Session
SESSION_COOKIE_NAME=ap_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_DAYS=7

# Secrets (DEV ONLY defaults exist; set real values in production)
API_KEY_HMAC_SECRET=dev-only-change-me-please
PASSWORD_HASH_PEPPER=dev-only-change-me-please
