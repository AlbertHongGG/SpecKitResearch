{
	"name": "jira-lite-backend",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"start": "node dist/src/main.js",
		"start:dev": "tsx watch src/main.ts",
		"lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"prisma/**/*.ts\"",
		"schema:validate": "node scripts/validate-openapi.mjs",
		"ci:api": "npm run schema:validate && npm run test:contract",
		"prisma:generate": "prisma generate",
		"prisma:validate": "prisma validate",
		"db:push": "prisma db push",
		"seed": "tsx prisma/seed.ts",
		"test": "vitest run tests",
		"test:watch": "vitest tests/foundation",
		"test:unit": "vitest run tests/unit tests/foundation",
		"test:integration": "vitest run tests/integration tests/foundation",
		"test:contract": "vitest run tests/contract tests/foundation",
		"test:csrf": "vitest run tests/integration/csrf.int.spec.ts tests/foundation",
		"test:performance": "vitest run tests/integration/performance-smoke.int.spec.ts tests/foundation"
	},
	"dependencies": {
		"@nestjs/common": "^10.4.15",
		"@nestjs/config": "^3.3.0",
		"@nestjs/core": "^10.4.15",
		"@nestjs/platform-express": "^10.4.15",
		"@prisma/client": "^6.5.0",
		"cookie-parser": "^1.4.7",
		"express-session": "^1.18.1",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@types/cookie-parser": "^1.4.8",
		"@types/express": "^5.0.1",
		"@types/express-session": "^1.18.1",
		"@types/node": "^22.13.10",
		"@types/supertest": "^6.0.3",
		"@typescript-eslint/eslint-plugin": "^8.26.0",
		"@typescript-eslint/parser": "^8.26.0",
		"eslint": "^9.22.0",
		"eslint-config-prettier": "^10.1.1",
		"prisma": "^6.5.0",
		"supertest": "^7.1.4",
		"tsx": "^4.19.3",
		"typescript": "^5.8.2",
		"vitest": "^3.0.8"
	}
}
