{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2022",
		"moduleResolution": "node",
		"outDir": "dist",
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"baseUrl": "."
	},
	"include": ["src/**/*.ts", "tests/**/*.ts", "prisma/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
