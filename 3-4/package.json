{
  "name": "payment-flow-sim",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm -w backend run dev",
    "dev:frontend": "npm -w frontend run dev",
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "build:backend": "npm -w backend run build",
    "build:frontend": "npm -w frontend run build",
    "build": "npm-run-all build:backend build:frontend",
    "test:backend": "npm -w backend run test",
    "test:frontend": "npm -w frontend run test",
    "test": "npm-run-all -p test:backend test:frontend",
    "e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier -w .",
    "format:check": "prettier -c ."
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "eslint": "^9.20.0",
    "vite": "^6.1.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.0",
    "typescript": "^5.7.3"
  }
}
