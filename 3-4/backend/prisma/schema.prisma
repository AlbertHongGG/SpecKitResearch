generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  created
  payment_pending
  paid
  failed
  cancelled
  timeout
}

enum SimulationScenario {
  success
  failed
  cancelled
  timeout
  delayed_success
}

enum ReturnMethod {
  query_string
  post_form
}

enum ReplayScope {
  webhook_only
  full_flow
}

enum JobStatus {
  pending
  running
  succeeded
  failed
  dead
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(USER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sessions        Session[]
  orders          Order[]
  webhookEndpoints WebhookEndpoint[]
  auditLogs       AuditLog[]
  replayRuns      ReplayRun[] @relation("ReplayRunCreatedBy")

  @@map("users")
}

model Session {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  expiresAtIdle    DateTime  @map("expires_at_idle")
  expiresAtAbsolute DateTime @map("expires_at_absolute")
  revokedAt        DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([expiresAtIdle])
  @@map("sessions")
}

model PaymentMethod {
  id          String   @id @default(uuid())
  code        String   @unique
  displayName String   @map("display_name")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([enabled, sortOrder])
  @@map("payment_methods")
}

model SimulationScenarioTemplate {
  id                 String             @id @default(uuid())
  scenario           SimulationScenario @unique
  enabled            Boolean            @default(true)
  defaultDelaySec    Int                @default(0) @map("default_delay_sec")
  defaultErrorCode   String?            @map("default_error_code")
  defaultErrorMessage String?           @map("default_error_message")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  @@map("simulation_scenario_templates")
}

model SystemSettings {
  id                          Int          @id
  allowedCurrencies           Json         @map("allowed_currencies")
  defaultReturnMethod         ReturnMethod @default(query_string) @map("default_return_method")
  sessionIdleSec              Int          @default(28800) @map("session_idle_sec")
  sessionAbsoluteSec          Int          @default(604800) @map("session_absolute_sec")
  webhookSecretGraceSecDefault Int         @default(604800) @map("webhook_secret_grace_sec_default")
  createdAt                   DateTime     @default(now()) @map("created_at")
  updatedAt                   DateTime     @updatedAt @map("updated_at")

  @@map("system_settings")
}

model WebhookEndpoint {
  id                      String    @id @default(uuid())
  userId                  String    @map("user_id")
  url                     String
  currentSecretCiphertext String    @map("current_secret_ciphertext")
  previousSecretCiphertext String?  @map("previous_secret_ciphertext")
  previousValidUntil      DateTime? @map("previous_valid_until")
  graceSec                Int       @default(604800) @map("grace_sec")
  lastRotatedAt           DateTime? @map("last_rotated_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  orders Order[]
  jobs   WebhookJob[]
  logs   WebhookLog[]

  @@unique([userId, url])
  @@map("webhook_endpoints")
}

model Order {
  id                String             @id @default(uuid())
  userId            String             @map("user_id")
  orderNo           String             @unique @map("order_no")
  status            OrderStatus        @default(created)
  amount            Int
  currency          String
  callbackUrl       String             @map("callback_url")
  returnMethod      ReturnMethod       @map("return_method")
  paymentMethodCode String             @map("payment_method_code")
  simulationScenario SimulationScenario @map("simulation_scenario")
  delaySec          Int                @default(0) @map("delay_sec")
  webhookDelaySec   Int?               @map("webhook_delay_sec")
  errorCode         String?            @map("error_code")
  errorMessage      String?            @map("error_message")
  webhookUrl        String?            @map("webhook_url")
  webhookEndpointId String?            @map("webhook_endpoint_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  completedAt       DateTime?          @map("completed_at")

  user            User            @relation(fields: [userId], references: [id])
  webhookEndpoint WebhookEndpoint? @relation(fields: [webhookEndpointId], references: [id])

  events     OrderStateEvent[]
  returnLogs ReturnLog[]
  webhookJobs WebhookJob[]
  webhookLogs WebhookLog[]
  replayRuns ReplayRun[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderStateEvent {
  id         String      @id @default(uuid())
  orderId    String      @map("order_id")
  fromStatus OrderStatus @map("from_status")
  toStatus   OrderStatus @map("to_status")
  trigger    String
  actorType  String      @map("actor_type")
  actorUserId String?    @map("actor_user_id")
  meta       Json? 
  occurredAt DateTime    @default(now()) @map("occurred_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId, occurredAt])
  @@map("order_state_events")
}

model ReplayRun {
  id              String      @id @default(uuid())
  orderId         String      @map("order_id")
  scope           ReplayScope
  createdByUserId String      @map("created_by_user_id")
  startedAt       DateTime    @default(now()) @map("started_at")
  finishedAt      DateTime?   @map("finished_at")
  status          String      @default("running")
  errorSummary    String?     @map("error_summary")

  order     Order @relation(fields: [orderId], references: [id])
  createdBy User  @relation("ReplayRunCreatedBy", fields: [createdByUserId], references: [id])

  returnLogs  ReturnLog[]
  webhookJobs WebhookJob[]
  webhookLogs WebhookLog[]

  @@index([orderId, startedAt])
  @@map("replay_runs")
}

model ReturnLog {
  id            String      @id @default(uuid())
  orderId       String      @map("order_id")
  replayRunId   String?     @map("replay_run_id")
  callbackUrl   String      @map("callback_url")
  returnMethod  ReturnMethod @map("return_method")
  payload       Json
  success       Boolean
  initiatedAt   DateTime    @default(now()) @map("initiated_at")
  clientSignalAt DateTime?  @map("client_signal_at")
  ackAt         DateTime?   @map("ack_at")
  errorSummary  String?     @map("error_summary")

  order     Order      @relation(fields: [orderId], references: [id])
  replayRun ReplayRun? @relation(fields: [replayRunId], references: [id])

  @@index([orderId, initiatedAt])
  @@map("return_logs")
}

model WebhookJob {
  id              String    @id @default(uuid())
  orderId         String    @map("order_id")
  replayRunId     String?   @map("replay_run_id")
  webhookEndpointId String? @map("webhook_endpoint_id")
  url             String
  eventId         String    @map("event_id")
  runAt           DateTime  @map("run_at")
  status          JobStatus @default(pending)
  attemptCount    Int       @default(0) @map("attempt_count")
  lastError       String?   @map("last_error")
  lockedAt        DateTime? @map("locked_at")
  lockedBy        String?   @map("locked_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  order     Order      @relation(fields: [orderId], references: [id])
  replayRun ReplayRun? @relation(fields: [replayRunId], references: [id])
  webhookEndpoint WebhookEndpoint? @relation(fields: [webhookEndpointId], references: [id])

  @@index([status, runAt])
  @@index([orderId, createdAt])
  @@map("webhook_jobs")
}

model WebhookLog {
  id                String   @id @default(uuid())
  orderId            String   @map("order_id")
  replayRunId        String?  @map("replay_run_id")
  webhookEndpointId  String?  @map("webhook_endpoint_id")
  url               String
  eventId            String   @map("event_id")
  signatureTimestamp Int      @map("signature_timestamp")
  signatureHeader    String   @map("signature_header")
  requestHeaders     Json     @map("request_headers")
  payload            Json
  sentAt             DateTime @default(now()) @map("sent_at")
  durationMs         Int?     @map("duration_ms")
  responseStatus     Int?     @map("response_status")
  responseBodyExcerpt String? @map("response_body_excerpt")
  success            Boolean
  errorSummary       String?  @map("error_summary")

  order     Order      @relation(fields: [orderId], references: [id])
  replayRun ReplayRun? @relation(fields: [replayRunId], references: [id])
  webhookEndpoint WebhookEndpoint? @relation(fields: [webhookEndpointId], references: [id])

  @@index([orderId, sentAt])
  @@index([eventId])
  @@map("webhook_logs")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?  @map("actor_user_id")
  actorRole   Role?    @map("actor_role")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  requestId   String?  @map("request_id")
  meta        Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actorUser User? @relation(fields: [actorUserId], references: [id])

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}
