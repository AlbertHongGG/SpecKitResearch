{
  "name": "@app/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "worker:dev": "tsx watch src/worker/main.ts",
    "worker:start": "node dist/worker/main.js",
    "worker:cleanup:dev": "tsx watch src/worker/main.ts -- --mode=cleanup",
    "worker:cleanup:start": "node dist/worker/main.js --mode=cleanup",
    "worker:all:dev": "tsx watch src/worker/main.ts -- --mode=all",
    "worker:all:start": "node dist/worker/main.js --mode=all",
    "lint": "eslint .",
    "pretest": "npm -w @app/contracts run build",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@app/contracts": "*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.2",
    "@prisma/client": "^6.4.1",
    "argon2": "^0.41.1",
    "fastify-plugin": "^5.0.1",
    "fastify": "^5.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prisma": "^6.4.1",
    "tsx": "^4.19.2",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
